{
  "name": "fd-ops-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/run-prisma-generate.mjs",
    "dev": "next dev --webpack -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "node scripts/run-prisma-generate.mjs",
    "worker:dev": "node scripts/worker.js",
    "worker:once": "node -e \"require('dotenv/config'); require('./scripts/worker.js')\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@prisma/config": "^7.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "playwright": "^1.58.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
